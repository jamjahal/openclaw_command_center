# ─── OpenClaw Command Center Configuration ──────────────
#
# Copy this file to .env and adjust as needed.
# Vite requires the VITE_ prefix for client-side env vars.
#
# ─── Provider Mode ───────────────────────────────────────
# "demo"  → Mock data with randomized agent movement (default)
# "live"  → Connects to an OpenClaw backend via WebSocket
#
VITE_PROVIDER_MODE=demo

# ─── Live Mode: WebSocket URL ────────────────────────────
# Only used when VITE_PROVIDER_MODE=live
# Point this at your OpenClaw agent event stream.
# See src/providers/useLiveProvider.js for the expected
# message format (AGENT_UPDATE, COLLABORATION_START, etc.)
#
VITE_WS_URL=ws://localhost:8080/agents
